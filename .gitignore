# Entornos virtuales y dependencias
.venv/
venv/
env/
ENV/

# Variables de entorno (NO subir secretos)
.env
.env.local
.env.*.local

# Cachés Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Build / packaging
build/
dist/
wheels/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Datos locales (no se suben al repo).
# Se mantiene la carpeta presente con un .gitkeep para que la estructura
# exista tras clonar.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Bases de datos locales
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Observabilidad local
.langfuse/

# IDEs / editores
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operativo
.DS_Store
Thumbs.db

# uv (uv.lock se versiona; cachés no)
.uv-cache/
