# =====================================================
# cloud-data-docs-assistant — plantilla de variables
# Copiar a `.env` y rellenar con valores reales.
# NUNCA commitear el archivo .env (está en .gitignore).
# =====================================================

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- PostgreSQL + pgvector (Docker local) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=cloud_data_docs
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Langfuse (observabilidad, self-hosted) ---
# Se completarán cuando levantemos el servicio Langfuse en docker-compose.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# --- Aplicación ---
LOG_LEVEL=INFO
APP_ENV=development
